{
  "name": "nvim-docker (go)",
  "build": {
    "context": "../../devcontainer-conf",
    "dockerfile": "../../devcontainer-conf/Dockerfile",
    "target": "go"
  },
  "remoteUser": "dev",
  "overrideCommand": true,
  "onCreateCommand": "sh -lc \"nvim --headless '+Lazy! sync' +qa || true\"",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
